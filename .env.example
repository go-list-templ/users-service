APP_NAME=grpc

GRPC_PORT=8080
GRPC_TIME=5s
GRPC_TIMEOUT=1s
GRPC_MAX_CONN_IDLE=15m
GRPC_MAX_CONN_AGE=30m

DIAGNOSTIC_PORT=8081
HTTP_TIMEOUT=5s
IDLE_TIMEOUT=30s

SHUTDOWN_TIMEOUT=30s

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_ADDRESS="${REDIS_HOST}:${REDIS_PORT}"

REDIS_DIAL_TIMEOUT=50ms
REDIS_READ_TIMEOUT=50ms
REDIS_WRITE_TIMEOUT=50ms

REDIS_MAX_RETRIES=-1
REDIS_MIN_RETRY_BACKOFF=5ms
REDIS_MAX_RETRY_BACKOFF=15ms

REDIS_POOL_SIZE=100
REDIS_MIN_IDLE_CONS=20
REDIS_POOL_TIMEOUT=10ms

DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=root
DB_DATABASE=users

DB_URL="postgres://${DB_USERNAME}:${DB_PASSWORD}@db:5432/${DB_DATABASE}?sslmode=disable"

DB_MAX_CONN=100
DB_MIN_CONN=5
DB_CONN_TIMEOUT=10s
DB_MAX_CONN_TIME=1h
DB_MAX_CONN_IDLE_TIME=5m
DB_HEALTH_CHECK_PERIOD=10m

OTEL_GRAFANA_PORT=3000
OTEL_GRPC_PORT=4317
OTEL_HOST=otel
OTEL_IS_TLS=false
OTEL_ENDPOINT="${OTEL_HOST}:${OTEL_GRPC_PORT}"
